# Diese Datei ist nur eine Vorlage und darf ins Git.
# Windows lokal (Semikolon):
# COMPOSE_FILE=docker-compose.yml;docker-compose.local.yml
# Linux/AWS (Doppelpunkt):
# COMPOSE_FILE=docker-compose.yml:docker-compose.aws.yml
# App-interne Compose-Werte wie NEO4J_URI werden gezielt im web-Service gesetzt.
# Diese Datei nicht als env_file fuer den neo4j-Service verwenden.

COMPOSE_FILE=docker-compose.yml;docker-compose.local.yml

SERVER_ADDRESS=:8080
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_strong_neo4j_password

ADMIN_USER=admin
ADMIN_PASSWORD=change_me_strong_admin_password

UPLOAD_DIR=data/uploads
STATIC_DIR=static
TEMPLATE_DIR=internal/templates

SMTP_HOST=smtp.invalid
SMTP_PORT=587
SMTP_USER=sender@example.invalid
SMTP_PASSWORD=change_me_smtp_password
CONTACT_MAIL_TO=contact@example.invalid
